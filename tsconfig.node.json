{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "types": ["node"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  // The Node-side (non-browser) TS: build config + tooling + Playwright e2e. The app
  // itself lives in tsconfig.app.json; everything that runs in Node instead of the
  // browser is checked here so `tsc -b` covers it. These files were previously
  // type-checked by nothing.
  "include": ["vite.config.ts", "playwright.config.ts", "tailwind.config.ts", "e2e/**/*.ts"]
}
